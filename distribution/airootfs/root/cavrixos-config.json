{
  "archinstall-language": "English",
  "audio_config": {
    "audio": "pipewire"
  },
  "bootloader_config": {
    "bootloader": "Systemd-boot",
    "uki": true,
    "removable": false
  },
  "debug": false,
  "hostname": "cavrixos",
  "kernels": ["linux-zen"],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US"
  },
  "mirror_config": {
    "custom_servers": [],
    "mirror_regions": {},
    "optional_repositories": []
  },
  "network_config": {
    "type": "nm"
  },
  "ntp": true,
  "offline": false,
  "packages": [
    "wine",
    "wine-gecko",
    "wine-mono",
    "winetricks",
    "bottles"
  ],
  "pacman_config": {
    "color": true,
    "parallel_downloads": 5
  },
  "profile_config": {
    "gfx_driver": "All open-source (default)",
    "greeter": "sddm",
    "profile": {
      "details": ["CavrixOS Desktop"],
      "main": "Desktop"
    }
  },
  "script": "cavrixos-install",
  "silent": false,
  "swap": {
    "enabled": false
  },
  "timezone": "UTC"
}
