#!/bin/bash
# Cavrix AI Installer Launcher
# Wraps the custom archinstall script with an animated ASCII logo

# Check if running as root
if [ "$EUID" -ne 0 ]; then
  echo -e "\033[1;31mPlease run as root (sudo cavrixos-installer)\033[0m"
  exit 1
fi

clear
tput civis # Hide cursor

# Colors for animation
C1="\033[38;2;6;182;212m"   # Cyan
C2="\033[38;2;37;99;235m"   # Blue
C3="\033[38;2;147;197;253m" # Light Blue
RESET="\033[0m"

# The ASCII Logo Array
read -r -d '' LOGO << 'EOF'
  ____    _    __     __ ____  ___ __  __     _    ___ 
 / ___|  / \   \ \   / /|  _ \|_ _| \/ \ \   / \  |_ _|
| |     / _ \   \ \ / / | |_) || | \  / \ \ / _ \  | | 
| |___ / ___ \   \ V /  |  _ < | | /  \  \ V ___ \ | | 
 \____/_/   \_\   \_/   |_| \_\___/_/\_\  \_/   \_|___|
                                                       
EOF

# Animation: Typewriter Fade-in
echo ""
echo ""
while IFS= read -r line; do
    for (( i=0; i<${#line}; i++ )); do
        char="${line:$i:1}"
        if [[ "$char" != " " ]]; then
            # Randomize color between cyan and blue
            num=$(( RANDOM % 3 ))
            if [ "$num" -eq 0 ]; then echo -en "${C1}${char}${RESET}"; fi
            if [ "$num" -eq 1 ]; then echo -en "${C2}${char}${RESET}"; fi
            if [ "$num" -eq 2 ]; then echo -en "${C3}${char}${RESET}"; fi
            sleep 0.002
        else
            echo -en " "
        fi
    done
    echo ""
done <<< "$LOGO"

echo -e "\n${C1} > Initiating Core Setup...${RESET}"
sleep 0.5
echo -e "${C2} > Loading Cavrix AI Configuration...${RESET}"
sleep 0.5
echo -e "${C3} > Launching Installer...${RESET}"
sleep 1

tput cnorm # Show cursor

# Ensure the custom profile is in Python's path
if [ -f "/opt/cavrixos-installer/src/core/main.py" ]; then
    python /opt/cavrixos-installer/src/core/main.py
else
    echo -e "\n\033[1;31mError: main.py not found in /opt/cavrixos-installer/\033[0m"
    echo "Installer payload was not copied into the ISO correctly."
    exit 1
fi
