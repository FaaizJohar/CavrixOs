[Unit]
Description=CavrixOS Installer Launcher
After=systemd-user-sessions.service plymouth-quit-wait.service
ConditionPathExists=/usr/local/bin/cavrixos-installer

[Service]
Type=simple
ExecStart=/usr/local/bin/cavrixos-installer
StandardInput=tty
StandardOutput=tty
TTYPath=/dev/tty1

[Install]
WantedBy=multi-user.target
